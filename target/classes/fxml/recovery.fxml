<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.himalayanvault.ui.RecoveryController"
           styleClass="root-pane">

    <ImageView fitHeight="680" fitWidth="1024" preserveRatio="false">
        <image>
            <Image url="@../images/background_image.png"/>
        </image>
    </ImageView>

    <VBox alignment="TOP_CENTER" spacing="0" styleClass="bg-pane">

        <HBox alignment="CENTER_LEFT"
              spacing="12"
              styleClass="header-section"
              prefHeight="80">

            <HBox.margin>
                <Insets top="20" left="40" right="40"/>
            </HBox.margin>

            <ImageView styleClass="logo-icon" fitHeight="50" fitWidth="50" preserveRatio="true">
                <image>
                    <Image url="@../images/icon.png"/>
                </image>
            </ImageView>

            <VBox spacing="2">
                <Label text="HIMALAYAN" styleClass="logo-text-main"/>
                <Label text="VAULT" styleClass="logo-text-sub"/>
            </VBox>
        </HBox>

        <VBox alignment="BOTTOM_CENTER"
              spacing="10"
              styleClass="form-wrapper"
              VBox.vgrow="ALWAYS"
              style="-fx-padding: 8 0 12 0; -fx-max-width: 440;">

            <Label text="Password Recovery" styleClass="form-title"/>

            <!-- STEP 1 -->
            <VBox fx:id="step1" spacing="8">
                <Label text="Username"/>
                <HBox styleClass="floating-field">
                    <TextField fx:id="usernameField" promptText="Enter your username" styleClass="form-input-field" HBox.hgrow="ALWAYS"/>
                    <Label text="Username" styleClass="floating-label"/>
                </HBox>

                <Label text="Enter your 16-word recovery code (space-separated)"/>
                <VBox>
                    <TextArea fx:id="recoveryWordsArea" prefRowCount="4" prefColumnCount="30" styleClass="form-input-field"/>
                    <Label text="Recovery words (space separated)" styleClass="floating-label"/>
                </VBox>

                <Label fx:id="err1" style="-fx-text-fill:#E24B4A;"/>
                <HBox spacing="8">
                    <Button fx:id="nextBtn1" text="Verify" onAction="#step1Next"/>
                    <Button fx:id="backBtn1" text="Back" onAction="#backBtn1"/>
                </HBox>
            </VBox>

            <!-- STEP 2 -->
            <VBox fx:id="step2" spacing="8" visible="false" managed="false">
                <Label text="Set New Password"/>
                <HBox spacing="6">
                    <PasswordField fx:id="newPwdField" promptText="New password" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="newPwdVis" visible="false" managed="false"/>
                    <Button fx:id="eye1" text="SHOW" onAction="#togglePwd1"/>
                </HBox>

                <HBox spacing="6">
                    <PasswordField fx:id="confirmPwdField" promptText="Confirm" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="confirmPwdVis" visible="false" managed="false"/>
                    <Button fx:id="eye2" text="SHOW" onAction="#togglePwd2"/>
                </HBox>

                <HBox spacing="4">
                    <Rectangle fx:id="seg1" width="40" height="6"/>
                    <Rectangle fx:id="seg2" width="40" height="6"/>
                    <Rectangle fx:id="seg3" width="40" height="6"/>
                    <Rectangle fx:id="seg4" width="40" height="6"/>
                </HBox>
                <Label fx:id="strengthLbl"/>
                <Label fx:id="matchLbl"/>
                <Label fx:id="err2" style="-fx-text-fill:#E24B4A;"/>

                <HBox spacing="8">
                    <Button fx:id="nextBtn2" text="Continue" onAction="#step2Next"/>
                    <Button fx:id="backBtn2" text="Back" onAction="#backBtn2"/>
                </HBox>
            </VBox>

            <!-- STEP 3 -->
            <VBox fx:id="step3" spacing="8" visible="false" managed="false">
                <Label text="Confirm Reset"/>
                <Label fx:id="confirmationMsg"/>
                <Label fx:id="err3" style="-fx-text-fill:#E24B4A;"/>
                <HBox spacing="8">
                    <Button fx:id="backBtn3" text="Back" onAction="#backBtn3"/>
                    <Button fx:id="completeBtn" text="Complete Reset" onAction="#completeRecovery"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>

</StackPane>
