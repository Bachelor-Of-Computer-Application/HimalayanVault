<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.himalayanvault.ui.VaultController"
            styleClass="root-pane"
            stylesheets="@../css/vault.css">

    <!-- ── Top Bar ── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="15">
            <VBox.margin><Insets/></VBox.margin>
            <Label styleClass="app-title" text="Himalayan Vault"/>
            <Separator orientation="VERTICAL"/>
            <Label styleClass="vault-status" text="✓ Vault Unlocked"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-secondary" text="Lock" onAction="#handleLock"/>
            <Button styleClass="btn-danger" text="⋯" onAction="#handleMenu"/>
        </HBox>
    </top>

    <!-- ── Main Content ── -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <VBox.margin><Insets top="30" left="20" right="20" bottom="20"/></VBox.margin>

            <!-- Welcome message -->
            <VBox alignment="CENTER" spacing="10">
                <Label styleClass="welcome-title" text="Welcome to Your Vault"/>
                <Label styleClass="welcome-subtitle" text="Your passwords are encrypted and safely stored"/>
            </VBox>

            <!-- Feature cards -->
            <HBox spacing="15" alignment="CENTER">
                <VBox styleClass="feature-card" alignment="CENTER" spacing="10">
                    <Label text="Secure" styleClass="feature-icon"/>
                    <Label text="Encrypted Storage" styleClass="feature-name"/>
                    <Label text="Military-grade encryption" styleClass="feature-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="feature-card" alignment="CENTER" spacing="10">
                    <Label text="Master" styleClass="feature-icon"/>
                    <Label text="Master Password" styleClass="feature-name"/>
                    <Label text="Single password unlocks all" styleClass="feature-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="feature-card" alignment="CENTER" spacing="10">
                    <Label text="Local" styleClass="feature-icon"/>
                    <Label text="Local Storage" styleClass="feature-name"/>
                    <Label text="Everything stays on your device" styleClass="feature-desc" wrapText="true"/>
                </VBox>
            </HBox>

            <!-- Quick actions -->
            <VBox alignment="CENTER" spacing="12" style="-fx-padding: 30;">
                <Label styleClass="section-title" text="Quick Actions"/>
                <Button styleClass="btn-primary" text="Add New Password" maxWidth="200"/>
                <Button styleClass="btn-secondary" text="View All Passwords" maxWidth="200"/>
                <Button styleClass="btn-secondary" text="Settings" maxWidth="200"/>
            </VBox>

            <!-- Info box -->
            <VBox styleClass="info-box" spacing="8" alignment="TOP_LEFT">
                <Label text="Tip:" styleClass="info-title"/>
                <Label text="Your vault data is stored locally in SQLite and encrypted with AES-256-GCM. Your master password is never stored." 
                       wrapText="true" styleClass="info-text"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
