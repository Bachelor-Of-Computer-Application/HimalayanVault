<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.himalayanvault.ui.VaultController"
            styleClass="root-pane"
            stylesheets="@../css/vault.css">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <Label styleClass="app-title" text="Himalayan Vault"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="vaultStatus" styleClass="vault-status" text="Vault Locked"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-secondary" text="Lock" onAction="#handleLock"/>
            <MenuButton fx:id="menuButton" styleClass="btn-secondary" text="Menu">
                <items>
                    <MenuItem text="Refresh" onAction="#handleRefresh"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Export Vault…" onAction="#handleExport"/>
                    <MenuItem text="Import Vault…" onAction="#handleImport"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="vault-content">
            <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>

            <VBox spacing="4">
                <Label styleClass="welcome-title" text="Your Vault"/>
                <Label fx:id="credentialCountLabel" styleClass="welcome-subtitle" text="0 stored credential(s)"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search site, username, or URL…"
                           styleClass="search-field" prefWidth="320" HBox.hgrow="ALWAYS"/>
                <Button text="Add" onAction="#handleAdd" styleClass="btn-primary"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <TableView fx:id="credentialTable" styleClass="credential-table" prefHeight="340">
                    <columns>
                        <TableColumn fx:id="siteColumn" text="Site" prefWidth="150"/>
                        <TableColumn fx:id="usernameColumn" text="Username" prefWidth="170"/>
                        <TableColumn fx:id="urlColumn" text="URL" prefWidth="200"/>
                        <TableColumn fx:id="notesColumn" text="Notes" prefWidth="120"/>
                        <TableColumn fx:id="updatedColumn" text="Updated" prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <Label text="No credentials saved yet. Add one or save from the browser extension." wrapText="true" styleClass="table-placeholder"/>
                    </placeholder>
                </TableView>
            </StackPane>

            <Label fx:id="detailLabel" styleClass="detail-label" text="Select a credential to view details." wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-row">
                <Button fx:id="editButton" text="Edit" onAction="#handleEdit" styleClass="btn-secondary" disable="true"/>
                <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" styleClass="btn-danger-soft" disable="true"/>
                <Button fx:id="copyUserButton" text="Copy Username" onAction="#handleCopyUsername" styleClass="btn-secondary" disable="true"/>
                <Button fx:id="copyPassButton" text="Copy Password" onAction="#handleCopyPassword" styleClass="btn-secondary" disable="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Export" onAction="#handleExport" styleClass="btn-primary"/>
                <Button text="Import" onAction="#handleImport" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
