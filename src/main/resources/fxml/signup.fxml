<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.himalayanvault.ui.SignupController"
           styleClass="root-pane">

    <ImageView fitHeight="640" fitWidth="1024" preserveRatio="false">
        <image>
            <Image url="@../images/background_image.png"/>
        </image>
    </ImageView>

    <VBox alignment="TOP_CENTER" spacing="0" styleClass="bg-pane">

        <HBox alignment="CENTER_LEFT"
              spacing="12"
              styleClass="header-section"
              prefHeight="80">

            <HBox.margin>
                <Insets top="20" left="40" right="40"/>
            </HBox.margin>

            <ImageView styleClass="logo-icon" fitHeight="50" fitWidth="50" preserveRatio="true">
                <image>
                    <Image url="@../images/icon.png"/>
                </image>
            </ImageView>

            <VBox spacing="2">
                <Label text="HIMALAYAN" styleClass="logo-text-main"/>
                <Label text="VAULT" styleClass="logo-text-sub"/>
            </VBox>
        </HBox>

        <VBox alignment="BOTTOM_CENTER"
              spacing="10"
              styleClass="form-wrapper"
              VBox.vgrow="ALWAYS"
              style="-fx-padding: 8 0 12 0; -fx-max-width: 480;">

            <Label text="Create a New Vault" styleClass="form-title"/>

            <!-- STEP 1 -->
            <VBox fx:id="step1" spacing="8">
                <Label text="Username"/>
                <HBox styleClass="floating-field">
                    <TextField fx:id="usernameField" promptText="Choose a username" styleClass="form-input-field" HBox.hgrow="ALWAYS"/>
                    <Label text="Username" styleClass="floating-label"/>
                </HBox>

                <Label text="Master Password"/>
                <HBox spacing="6" styleClass="floating-field">
                    <PasswordField fx:id="pwdField" promptText="Master password" styleClass="form-input-field" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="pwdVis" visible="false" managed="false" styleClass="form-input-field"/>
                    <Label text="Master Password" styleClass="floating-label"/>
                    <Button fx:id="eye1" text="SHOW" onAction="#togglePwd1"/>
                </HBox>

                <Label text="Confirm Password"/>
                <HBox spacing="6" styleClass="floating-field">
                    <PasswordField fx:id="confirmField" promptText="Confirm" onAction="#step1Next" styleClass="form-input-field" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="confirmVis" visible="false" managed="false" onAction="#step1Next" styleClass="form-input-field"/>
                    <Label text="Confirm Password" styleClass="floating-label"/>
                    <Button fx:id="eye2" text="SHOW" onAction="#togglePwd2"/>
                </HBox>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Rectangle fx:id="seg1" width="40" height="6"/>
                    <Rectangle fx:id="seg2" width="40" height="6"/>
                    <Rectangle fx:id="seg3" width="40" height="6"/>
                    <Rectangle fx:id="seg4" width="40" height="6"/>
                </HBox>
                <Label fx:id="strengthLbl"/>
                <Label fx:id="matchLbl"/>
                <Label fx:id="err1" style="-fx-text-fill: #E24B4A;"/>

                <Button text="Continue" onAction="#step1Next"/>
                <Hyperlink text="Back to Login" onMouseClicked="#switchToLogin"/>
            </VBox>

            <!-- STEP 2 -->
            <VBox fx:id="step2" spacing="8" visible="false" managed="false">
                <Label text="Recovery Words"/>
                <GridPane fx:id="wordGrid" hgap="6" vgap="6"/>
                <CheckBox fx:id="savedCheck" text="I have saved the words"/>
                <Label fx:id="err2" style="-fx-text-fill: #E24B4A;"/>
                <Button text="I've saved it — Continue" onAction="#step2Next"/>
                <Button text="Back" onAction="#back1"/>
            </VBox>

            <!-- STEP 3 -->
            <VBox fx:id="step3" spacing="8" visible="false" managed="false">
                <Label text="Verify words"/>
                <HBox spacing="6">
                    <TextField fx:id="v1" promptText="#1"/>
                    <TextField fx:id="v2" promptText="#2"/>
                    <TextField fx:id="v3" promptText="#3"/>
                </HBox>
                <Label fx:id="vlbl1"/>
                <Label fx:id="vlbl2"/>
                <Label fx:id="vlbl3"/>
                <Label fx:id="err3" style="-fx-text-fill: #E24B4A;"/>
                <Button text="Create Vault" onAction="#createVault"/>
                <Button text="Back" onAction="#back2"/>
            </VBox>

        </VBox>
    </VBox>

</StackPane>
