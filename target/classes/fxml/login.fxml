<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.himalayanvault.ui.LoginController"
           styleClass="root-pane">

    <!-- BACKGROUND IMAGE -->
    <ImageView fitHeight="${rootPane.height}" fitWidth="${rootPane.width}" preserveRatio="false">
        <image>
            <Image url="@../images/background_image.png"/>
        </image>
    </ImageView>

    <!-- BACKGROUND GRADIENT OVERLAY + CONTENT -->
    <VBox alignment="TOP_CENTER"
          spacing="0"
          styleClass="bg-pane">

        <!-- TOP LOGO HEADER -->
        <HBox fx:id="headerSection"
              alignment="CENTER_LEFT"
              spacing="12"
              styleClass="header-section"
              prefHeight="84"
              VBox.vgrow="NEVER">

            <HBox.margin>
                <Insets top="20" left="40" right="40"/>
            </HBox.margin>

            <ImageView styleClass="logo-icon" fitHeight="50" fitWidth="50" preserveRatio="true">
                <image>
                    <Image url="@../images/icon.png"/>
                </image>
            </ImageView>

            <VBox spacing="2" styleClass="brand-copy">
                <Label text="HIMALAYAN" styleClass="logo-text-main"/>
                <Label text="VAULT" styleClass="logo-text-sub"/>
            </VBox>

                <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- MAIN CONTENT -->
        <HBox fx:id="contentShell" styleClass="content-shell" alignment="CENTER">
            <VBox fx:id="heroPanel" styleClass="hero-panel" spacing="14">
                <Label text="Secure access built for your vault"
                       styleClass="hero-kicker"/>
                <Label text="Log in with speed, protect with biometrics, and keep your passwords locked down."
                       wrapText="true"
                       styleClass="hero-title"/>
                <Label text="Designed for quick unlocks, clean focus, and a calm security-first workflow."
                       wrapText="true"
                       styleClass="hero-copy"/>

                <VBox spacing="10" styleClass="feature-list">
                    <HBox spacing="10" styleClass="feature-item">
                        <Region styleClass="feature-dot"/>
                        <Label text="Fast login with username and master password" wrapText="true" styleClass="feature-text"/>
                    </HBox>
                    <HBox spacing="10" styleClass="feature-item">
                        <Region styleClass="feature-dot"/>
                        <Label text="Biometric unlock button for supported devices" wrapText="true" styleClass="feature-text"/>
                    </HBox>
                    <HBox spacing="10" styleClass="feature-item">
                        <Region styleClass="feature-dot"/>
                        <Label text="Recovery and sign-up flows stay easy to reach" wrapText="true" styleClass="feature-text"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="formWrapper"
                  alignment="CENTER"
                  spacing="12"
                  styleClass="form-wrapper"
                  VBox.vgrow="ALWAYS">

                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="form-chip-row">
                    <Region styleClass="chip-indicator"/>
                    <Label text="Vault Login" styleClass="form-chip"/>
                </HBox>

                <Label fx:id="formTitle"
                       text="Welcome Back"
                       styleClass="form-title"/>

                <Label text="Unlock your vault in one step." styleClass="form-subtitle" wrapText="true"/>

                <HBox fx:id="warnBox"
                      styleClass="warn-box"
                      managed="false"
                      visible="false"
                      alignment="CENTER_LEFT"
                      spacing="8">
                    <Label fx:id="warnLabel"
                           text=""
                           styleClass="warn-label"
                           wrapText="true"
                           HBox.hgrow="ALWAYS"/>
                </HBox>

                <VBox spacing="12" styleClass="field-stack">
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="form-input-field"/>

                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="form-input-field"
                                   onAction="#handleUnlock"/>

                </VBox>

                <HBox fx:id="buttonContainer"
                      alignment="CENTER"
                      spacing="12"
                      styleClass="button-container">

                    <Button fx:id="unlockButton"
                            text="LOG IN"
                            styleClass="primary-button"
                            onAction="#handleUnlock"
                            prefHeight="40"
                            prefWidth="150"/>

                    <Button fx:id="eyeButton"
                            onAction="#handleBiometric"
                            text=""
                            styleClass="biometric-button"
                            prefHeight="40"
                            prefWidth="44">
                        <graphic>
                            <StackPane prefWidth="18" prefHeight="18" styleClass="biometric-icon">
                                <Region styleClass="biometric-icon-ring biometric-icon-ring-outer"/>
                                <Region styleClass="biometric-icon-ring biometric-icon-ring-mid"/>
                                <Region styleClass="biometric-icon-dot"/>
                            </StackPane>
                        </graphic>
                    </Button>
                </HBox>

                <HBox fx:id="linksContainer"
                      alignment="CENTER"
                      spacing="16"
                      styleClass="links-container">
                    <Hyperlink text="Forgot Password"
                               styleClass="form-link"
                               onAction="#handleRecovery"/>
                    <Label text="|" styleClass="link-separator"/>
                    <Hyperlink text="Sign Up"
                               styleClass="form-link"
                               onAction="#navigateToSignup"/>
                </HBox>

            </VBox>
        </HBox>

    </VBox>

</StackPane>